# mkinitcpio preset file for the 'linux-znver4-bore' package
# Replica tu setup UKI del kernel stock: genera una Unified Kernel Image
# en /boot/EFI/Linux/ que systemd-boot autodescubre (sin tocar el bootloader).

ALL_kver="/boot/vmlinuz-linux-znver4-bore"

PRESETS=('default')

default_uki="/boot/EFI/Linux/arch-linux-znver4-bore.efi"
default_options="--splash /usr/share/systemd/bootctl/splash-arch.bmp"
